    {
      "name": "addToken",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Convertir la respuesta a un objeto JSON\r",
              "const response = pm.response.json();\r",
              "\r",
              "// 2. Verificar que el status sea 200 y que el token exista\r",
              "if (pm.response.code === 200 && response.token) {\r",
              "    \r",
              "    // 3. Guardar el token en la variable de colección\r",
              "    pm.collectionVariables.set(\"token\", response.token);\r",
              "    \r",
              "    console.log(\"Token guardado correctamente: \" + response.token);\r",
              "} else {\r",
              "    console.error(\"No se pudo recuperar el token de la respuesta\");\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
